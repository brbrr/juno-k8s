apiVersion: v1
kind: Secret
metadata:
  name: staking-secret
  namespace: starknet
  labels:
    app: staking
    component: credentials
type: Opaque
stringData:
  config.json: |
    {
      "signer": {
        "privateKey": "0xYOUR_PRIVATE_KEY_HERE",
        "operationalAddress": "0xYOUR_OPERATIONAL_ADDRESS_HERE"
      }
    }
